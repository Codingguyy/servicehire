  "private": true,
 "scripts": {
  "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",

  "dev:backend": "npx ts-node-dev --respawn --transpile-only --project tsconfig.backend.json backend/index.ts",
